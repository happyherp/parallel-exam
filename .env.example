# Required for Phase 3 (surface text rewording) and Phase 5 (template extraction).
# Obtain your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for rewording (default: claude-haiku-4-5-20251001).
# Sonnet is also fine; haiku is cheapest and accurate enough for surface rewording.
# REWORD_MODEL=claude-sonnet-4-6
